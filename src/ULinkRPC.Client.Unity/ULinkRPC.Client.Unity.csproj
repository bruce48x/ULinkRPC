<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>netstandard2.1;net10.0</TargetFrameworks>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>ULinkRPC.Client.Unity</PackageId>
    <Version>0.1.0</Version>
    <Authors>ULinkRPC</Authors>
    <Description>Unity-oriented high-level client options and connection presets for ULinkRPC.</Description>
    <PackageTags>rpc;unity;client;tcp;websocket;kcp;json;memorypack</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\ULinkRPC.Client\ULinkRPC.Client.csproj" />
    <ProjectReference Include="..\ULinkRPC.Serializer.MemoryPack\ULinkRPC.Serializer.MemoryPack.csproj" />
    <ProjectReference Include="..\ULinkRPC.Serializer.Json\ULinkRPC.Serializer.Json.csproj" />
    <ProjectReference Include="..\ULinkRPC.Transport.Tcp\ULinkRPC.Transport.Tcp.csproj" />
    <ProjectReference Include="..\ULinkRPC.Transport.WebSocket\ULinkRPC.Transport.WebSocket.csproj" />
    <ProjectReference Include="..\ULinkRPC.Transport.Kcp\ULinkRPC.Transport.Kcp.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="" />
  </ItemGroup>
</Project>
